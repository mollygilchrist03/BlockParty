# Neon Postgres connection string (get from console.neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/blockparty?sslmode=require"

# Generate with: npx auth secret
AUTH_SECRET=""

# Vercel Blob store token, for newsletter PDF uploads.
# Create a Blob store in the Vercel project's Storage tab, or run
# `vercel env pull` once one exists to fetch this locally.
BLOB_READ_WRITE_TOKEN=""

# Google OAuth (residents only — admin/board sign in with credentials).
# Create an OAuth client at console.cloud.google.com > APIs & Services >
# Credentials > Create Credentials > OAuth client ID > Web application.
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://<your-production-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Platform owner. Whichever Google account signs in with this exact email
# gets auto-provisioned/promoted to the "owner" role on sign-in (see the
# jwt() callback in src/auth.ts) — not tied to any neighborhood, manages
# neighborhoods and HOA admin accounts from /dashboard/owner.
OWNER_EMAIL=""

# Resend API key — emails the owner when a new neighborhood request comes
# in, and emails the requester directly on approve (their login link +
# temp password) or deny. Get one free at resend.com.
#
# Without a verified domain, Resend runs in "test mode": the from address
# is forced to onboarding@resend.dev, and it will ONLY deliver to the
# email address on your Resend account — sending to anyone else 403s.
# The owner-notification email is unaffected (it always goes to you), but
# approve/deny emails to real requesters need a verified domain
# (resend.com/domains) before they'll actually reach anyone but you.
RESEND_API_KEY=""
# Optional: defaults to Resend's shared onboarding@resend.dev sender if
# unset. Set this only if you've verified your own domain with Resend.
RESEND_FROM_EMAIL=""

# Optional: who gets the "new neighborhood request" notification email.
# Defaults to OWNER_EMAIL if unset.
OWNER_NOTIFICATION_EMAIL=""

# Optional: absolute site URL used in emails (the login link sent on
# approval). Falls back to Vercel's own deployment URL in production, or
# localhost in dev, if unset.
NEXT_PUBLIC_SITE_URL=""
